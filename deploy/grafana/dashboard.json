{
  "title": "金融顾问平台监控面板",
  "version": 1,
  "uid": "financial-advisor",
  "panels": [
    {
      "title": "Agent 调用次数",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "spring_ai_agent_invocations_total",
          "legendFormat": "Agent调用"
        }
      ],
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 0 }
    },
    {
      "title": "工具调用耗时 (P50/P95)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "spring_ai_tool_execution_duration_seconds_bucket",
          "legendFormat": "工具耗时"
        }
      ],
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 0 }
    },
    {
      "title": "Token 消耗统计",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "spring_ai_token_usage_total",
          "legendFormat": "Token消耗"
        }
      ],
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 }
    },
    {
      "title": "HTTP 请求吞吐量",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_count[1m])",
          "legendFormat": "{{method}} {{uri}}"
        }
      ],
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 }
    },
    {
      "title": "JVM 堆内存使用",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{area=\"heap\"}",
          "legendFormat": "{{id}}"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 }
    },
    {
      "title": "响应时间分布",
      "type": "heatmap",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_bucket[1m])",
          "legendFormat": "响应时间"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 }
    }
  ],
  "schemaVersion": 36
}
